rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'salahmohamedzouagui@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'order']) && data.keys().size() == 2 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.order is number;
    }

    function isValidDisease(data) {
      return data.keys().hasAll(['categoryId', 'name', 'definition', 'epidemiology', 'physiopathology', 'etiologies', 'clinical', 'diagnosis', 'differentialDiagnosis', 'complications', 'treatment', 'keyPoints']) && data.keys().size() == 12 &&
             data.categoryId is string && data.categoryId.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.definition is map &&
             data.epidemiology is map &&
             data.physiopathology is map &&
             data.etiologies is list && data.etiologies.size() <= 50 &&
             data.clinical is map &&
             data.diagnosis is map &&
             data.differentialDiagnosis is map &&
             data.complications is map &&
             data.treatment is map &&
             data.keyPoints is map;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'displayName', 'role', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 128 &&
             data.role is string && data.role in ['user', 'admin'] &&
             data.createdAt == request.time;
    }

    function isValidUserUpdate(data) {
      return data.keys().hasAll(['email', 'displayName', 'role', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 128 &&
             data.role is string && data.role == existing().role &&
             data.createdAt == existing().createdAt;
    }

    function isValidFavorite(data) {
      return data.keys().hasAll(['diseaseId', 'diseaseName', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.diseaseId is string && data.diseaseId.size() <= 128 &&
             data.diseaseName is string && data.diseaseName.size() <= 200 &&
             data.createdAt == request.time;
    }

    match /categories/{categoryId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.name is string;
      allow create: if isAdmin() && isValidId(categoryId) && isValidCategory(incoming());
      allow update: if (isAdmin() && isValidId(categoryId) && isValidCategory(incoming()) && incoming().diff(existing()).affectedKeys().hasAny(['name', 'order']));
      allow delete: if isAdmin() && isValidId(categoryId);
    }

    match /diseases/{diseaseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.categoryId is string;
      allow create: if isAdmin() && isValidId(diseaseId) && isValidDisease(incoming()) && exists(/databases/$(database)/documents/categories/$(incoming().categoryId));
      allow update: if (isAdmin() && isValidId(diseaseId) && isValidDisease(incoming()) && incoming().diff(existing()).affectedKeys().hasAny(['categoryId', 'name', 'definition', 'epidemiology', 'physiopathology', 'etiologies', 'clinical', 'diagnosis', 'differentialDiagnosis', 'complications', 'treatment', 'keyPoints']));
      allow delete: if isAdmin() && isValidId(diseaseId);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isSignedIn() && isAdmin() && resource.data.role is string;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUser(incoming()) && (incoming().role == 'user' || request.auth.token.email == 'salahmohamedzouagui@gmail.com');
      allow update: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUserUpdate(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email']);
      allow delete: if isAdmin() && isValidId(userId);

      match /favorites/{favoriteId} {
        allow get: if isSignedIn() && request.auth.uid == userId;
        allow list: if isSignedIn() && request.auth.uid == userId && resource.data.diseaseId is string;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(favoriteId) && isValidFavorite(incoming()) && exists(/databases/$(database)/documents/diseases/$(incoming().diseaseId));
        allow delete: if isSignedIn() && request.auth.uid == userId && isValidId(favoriteId);
      }
    }
  }
}
